# Backend server URL (Express server)
NEXT_PUBLIC_APP_URL=http://localhost:4000

# NextAuth.js / Google Sign-In (required for Get Started)
# Get these from https://console.cloud.google.com/apis/credentials
AUTH_SECRET=your-random-secret  # Run: npx auth secret
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# App URL for OAuth redirect (use in production)
# AUTH_URL=https://www.pdf-to-video.com
